# Replace YOUR-IP-WITH-DASHES with your Hetzner IP (e.g. 1.2.3.4 → 1-2-3-4)
# Full address will be: https://1-2-3-4.sslip.io
# Let's Encrypt certificate is obtained automatically.

{$CADDY_HOST} {
    reverse_proxy cncsearch:8080
}

# ── Cânticos públicos da Paróquia ────────────────────────────────────────────
# Requer registo DNS: A canticos → IP do servidor
# Certificado HTTPS obtido automaticamente pelo Caddy via Let's Encrypt.
# Apenas as rotas /paroquia/* são expostas — admin inacessível neste domínio.
canticos.paroquiacasaldecambra.pt {
    # Raiz → directório de cânticos
    redir / /paroquia permanent

    # Serve apenas as páginas públicas da paróquia
    handle /paroquia* {
        reverse_proxy cncsearch:8080
    }

    # Qualquer outra rota → redireciona para o directório (não expõe admin)
    handle {
        redir * /paroquia permanent
    }
}
