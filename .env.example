# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=/data/cncsearch.db

# ── Embeddings ────────────────────────────────────────────────────────────────
# "jina" (default, free API) or "local" (sentence-transformers on CPU)
EMBEDDING_PROVIDER=jina

# Required when EMBEDDING_PROVIDER=jina
# Free account at https://jina.ai — 1M tokens/month
JINA_API_KEY=jina_...

# ── Web UI ────────────────────────────────────────────────────────────────────
# Random secret for signing session cookies — change this!
WEB_SECRET_KEY=change-me-to-a-random-string

# Password set on first run (change via Settings page afterwards)
WEB_INITIAL_PASSWORD=admin

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
